# Supabase Auth Test Credentials for Playwright E2E Tests
# Copy this file to '.env' and fill in your actual credentials.

# 1. Super Admin Account
# This user must have 'super_admin' role in your 'profiles' table.
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=your_admin_password

# 2. Staff Account
# This user must have 'staff' role in your 'profiles' table.
TEST_STAFF_EMAIL=staff@example.com
TEST_STAFF_PASSWORD=your_staff_password
